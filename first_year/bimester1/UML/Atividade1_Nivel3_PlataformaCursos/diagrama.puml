@startuml Plataforma de Cursos Online

left to right direction
skinparam actorStyle awesome

actor "Aluno" as aluno
actor "Administrador" as admin

rectangle "Plataforma de Cursos Online" {
    usecase "Registrar-se" as UC1
    usecase "Fazer Login" as UC2
    usecase "Inscrever-se em Curso" as UC3
    usecase "Assistir Aulas" as UC4
    usecase "Gerar Certificado" as UC5
    usecase "Cadastrar Curso" as UC6
    usecase "Remover Curso" as UC7
}

aluno --> UC1
aluno --> UC2
aluno --> UC3
aluno --> UC4
aluno --> UC5

admin --> UC2
admin --> UC6
admin --> UC7

UC3 ..> UC2 : <<include>>
UC4 ..> UC3 : <<include>>
UC5 ..> UC4 : <<include>>
UC6 ..> UC2 : <<include>>
UC7 ..> UC2 : <<include>>

@enduml
