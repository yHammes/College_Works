@startuml Biblioteca Digital

left to right direction
skinparam actorStyle awesome

actor "Usuário" as usuario
actor "Funcionário" as funcionario

rectangle "Sistema Biblioteca Digital" {
    usecase "Fazer Login" as UC1
    usecase "Pesquisar Livros" as UC2
    usecase "Pesquisar por Título" as UC2a
    usecase "Pesquisar por Autor" as UC2b
    usecase "Pesquisar por Categoria" as UC2c
    usecase "Reservar Livro" as UC3
    usecase "Cancelar Reserva" as UC4
    usecase "Adicionar Livro" as UC5
    usecase "Remover Livro" as UC6
}

usuario --> UC1
usuario --> UC2
usuario --> UC3
usuario --> UC4

funcionario --> UC1
funcionario --> UC5
funcionario --> UC6

UC2 <.. UC2a : <<extend>>
UC2 <.. UC2b : <<extend>>
UC2 <.. UC2c : <<extend>>

UC3 ..> UC1 : <<include>>
UC4 ..> UC1 : <<include>>
UC5 ..> UC1 : <<include>>
UC6 ..> UC1 : <<include>>

@enduml
